{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Flow Docs",
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#2563EB"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Product",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart", "core-concepts", "development"]
          },
          {
            "group": "IDE workspace",
            "pages": [
              "ide/overview",
              "ide/projects",
              "ide/editor",
              "ide/design-preview-builds",
              "ide/flow-ai"
            ]
          },
          {
            "group": "Project settings",
            "pages": [
              "project-settings/general",
              "project-settings/secrets",
              "project-settings/environment-variables",
              "project-settings/capabilities",
              "project-settings/certificates-profiles"
            ]
          }
        ]
      },
      {
        "tab": "Platform",
        "groups": [
          {
            "group": "Architecture",
            "pages": [
              "architecture/overview",
              "architecture/services",
              "architecture/vault-backed-configuration"
            ]
          },
          {
            "group": "API reference",
            "pages": ["api-reference/gateway", "api-reference/projects-service", "api-reference/vault-service"]
          },
          {
            "group": "Operations",
            "pages": [
              "operations/local-development",
              "operations/environment-variables",
              "operations/deployment"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Flow Cloud",
          "href": "https://github.com/usehaptic/flow-cloud",
          "icon": "book-open-cover"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/usehaptic",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/usehaptic/flow-cloud"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Flow",
      "href": "https://flow.usehaptic.com"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/usehaptic"
    }
  }
}
